@echo off
chcp 65001 >nul
cls
echo ============================================================
echo          ПАРСЕР ЛЕКАРСТВЕННЫХ СРЕДСТВ С ЕИС
echo ============================================================
echo.
echo Выберите режим работы:
echo.
echo 1. Поиск и парсинг контрактов (автоматический поиск ссылок)
echo    - Автоматически находит контракты по названию лекарства
echo    - Парсит данные из найденных страниц
echo    - Результат сохраняется в Excel/CSV
echo.
echo 2. Парсинг по прямой ссылке (ручной ввод URL)
echo    - Для парсинга конкретной страницы контракта
echo.
echo 3. Выход
echo.
:start
set /p choice="Введите номер режима (1-3): "

if "%choice%"=="1" goto mode1
if "%choice%"=="2" goto mode2
if "%choice%"=="3" goto end
echo.
echo Неверный выбор. Попробуйте снова.
goto start

:mode1
cls
echo.
echo ============================================================
echo РЕЖИМ 1: ПОИСК И ПАРСИНГ КОНТРАКТОВ
echo ============================================================
echo.
echo Запуск окна поиска контрактов...
echo.
echo В открывшемся окне вы сможете указать:
echo   * Название лекарства (например: АЗИТРОМИЦИН)
echo   * Даты периода поиска
echo   * Максимальное количество контрактов для обработки
echo   * Фильтры: только Москва/МО или только РОСУНИМЕД
echo.
echo Нажмите любую клавишу для продолжения...
pause >nul
python eis_parser.py --search-gui
goto end

:mode2
cls
echo.
echo ============================================================
echo РЕЖИМ 2: ПАРСИНГ ПО ПРЯМОЙ ССЫЛКЕ
echo ============================================================
echo.
echo Запуск окна парсинга по ссылке...
echo.
python eis_parser.py --gui
goto end

:end
cls
echo.
echo До свидания!
echo.
timeout /t 2 >nul

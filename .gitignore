```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.tsbuildinfo

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temporary files
*.tmp
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# Compiled files
*.exe
*.dll
*.so
*.a
*.o
*.obj
*.out

# MyPy cache
.mypy_cache/
__pycache__/

# Pytest cache
.pytest_cache/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```
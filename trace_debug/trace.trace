{"type":"after","callId":"call@35","endTime":6803.16,"result":{"value":"<!DOCTYPE html><html><head>\n  <meta http-equiv=\"content-type\" content=\"text/html; charset=UTF-8\">\n  <meta name=\"apple-itunes-app\" content=\"app-id=1457694118\">\n  <meta name=\"google-play-app\" content=\"app-id=ru.gov.zakupki.mobile\">\n\n  <title>Карточка контракта</title>\n\n  <script async=\"\" src=\"https://mc.yandex.ru/metrika/tag.js\"></script><script type=\"text/javascript\">\n      var contextPath = \"/epz/contract\";\n  </script>\n\n  <script type=\"text/javascript\" src=\"/static/useractivityrecordplugin/js/recordSupportSystem.js\"></script><style type=\"text/css\">.uap-table{\r\n    width: 100%;\r\n    align-content: center;\r\n}\r\n.uap-recordPanel.hidden{\r\n    display: none;\r\n}\r\n.uap-recordPanel{\r\n    display: flex;\r\n    position: fixed;\r\n    bottom: 0px;\r\n    left: 50%;\r\n    margin-left:-260px;\r\n}\r\n.uap-recordPanel, .recordPanel * {\r\n    font-size: 14px;\r\n}\r\n\r\n.uap-recordPanel {\r\n    width: 520px;\r\n    z-index: 10001;\r\n    background: white;\r\n    border-radius: 4px;\r\n    box-shadow: 0 0 10px rgba(0,0,0,.2);\r\n}\r\n\r\na.uap-link {\r\n    text-decoration: none;\r\n    color: #609fea;\r\n    font-size: 14px;\r\n    font-weight: 600;\r\n}\r\n.uap-recordPanel__info{\r\n    width: 100%;\r\n    text-align: center;\r\n    font-family: serif;\r\n}\r\n\r\ntd.recordPanel__timer {\r\n    vertical-align: middle;\r\n}\r\n\r\n.recordPanel__text {\r\n    padding-top: 4px;\r\n}\r\n\r\ntd.uap-recordPanel__stop{\r\n    padding: 3px!important;\r\n}\r\n\r\n.uap-recordPanel__info::after{\r\n    content : \"\";\r\n    position: absolute;\r\n    left    : 144px;\r\n    z-index: 10100;\r\n    top  : 13px;\r\n    width  : 1px;\r\n    height   : 50%;  /* or 100px */\r\n    background: #c7d1e0;\r\n}\r\n.uap-recordPanel__circle{\r\n    vertical-align: super;\r\n}\r\n\r\n.uap-buttonStop{\r\n    border: none;\r\n    width: 100%;\r\n    background-color: white;\r\n    background: url(data:image/png;base64,) no-repeat 10% 50%;\r\n    background-size: 35px;\r\n    height: 44px !important;\r\n    padding: 8px;\r\n}\r\n\r\n.uap-buttonStop:hover{\r\n    background: url(data:image/png;base64,) no-repeat 10% 50%;\r\n    background-size: 35px;\r\n    background-color: rgb(243, 243, 243);\r\n    padding:8px;\r\n    cursor: pointer;\r\n}\r\n\r\n.uap-recordPanel__btn{\r\n    cursor: pointer;\r\n}\r\n\r\n.uap-buttonStop p{\r\n    margin:0px;\r\n    margin-left: 50px !important;\r\n    user-select: none;\r\n}\r\n.uap-textRecord{\r\n    margin: 0px;\r\n    font-size: 22px;\r\n    cursor: default;\r\n}\r\n.uap-textRecord::selection{\r\n    background: transparent;\r\n}\r\n.uap-img_circle{\r\n    margin-top: 60%;\r\n    margin-bottom: 40%;\r\n    padding-left: 10px;\r\n}\r\n.uap-imgClose{\r\n    width: 20px;\r\n    margin: 8px 5px 5px;\r\n}</style><style type=\"text/css\">.show-menu {\n    text-decoration: none;\n    width: 200px;\n    text-align: left;\n    height: 50px;\n}\n.menu__item{\n    border: 1px solid black;\n    width: 200px;\n    padding: 8px;\n    background: #F2F2F2;\n    cursor: pointer;\n    height: 30px;\n}\n\n.show-menu:hover {\n    cursor: pointer;\n    color: blue;\n}\n\n.menu {\n    margin: 0;\n    padding: 0;\n    list-style: none;\n}\n\n.menu--hide {\n    display: none;\n}\n\n.menu--show {\n    display: block;\n}\n</style><style type=\"text/css\">/*МО*/\n.uap-modal-update,\n.uap-modal-limit,\n.uap-modal-continue,\n.uap-modal-no-response,\n.uap-modal-no-support,\n.uap-modal-is-running,\n.uap-modal-success-update,\n.uap-modal-update-wait,\n.uap-modal-plugin-rule,\n.uap-modal-graphical-shell,\n.uap-modal-error-update {\n    position: fixed;\n    z-index: 10001;\n    align-items: center;\n    display: flex;\n    left: 0;\n    top: 0;\n    width: 100%;\n    height: 100%;\n    overflow: auto;\n    background-color: rgba(0,0,0,0.4);\n}\n\n/*МО фон*/\n.uap-modal-content {\n    background-color: #fefefe;\n    margin: auto;\n    border: 1px solid #888;\n    max-width: 430px;\n    font-family: serif;\n}\n\n.uap-modal-content-large{\n    background-color: #fefefe;\n    margin: auto;\n    border: 1px solid #888;\n    max-width: 590px;\n    font-family: serif;\n}\n\n.uap-modal-content-large-no-plugin{\n    background-color: #fefefe;\n    margin: auto;\n    border: 1px solid #888;\n    max-width: 630px;\n    font-family: serif;\n}\n\n.uap-modal-large {\n    max-width: 600px !important;\n    width: 528px;\n}\n.uap-rule-modal-title {\n    margin: 24px 24px 30px 24px !important;\n}\n\n/*Текст ошибки*/\n.uap-modal-text-error{\n    color: red;\n    font-weight: bold;\n    font-size: 15px;\n    text-align: left;\n    margin: 10px;\n}\n/*Контейнер содержимого МО*/\n.uap-modal-container-content{\n     border-top: 1px #dbdfec solid;\n     border-bottom: 1px #dbdfec solid;\n     width: 100%;\n }\n\n.uap-modal-container-content-no-top-border{\n    border-bottom: 1px #dbdfec solid;\n    width: 100%;\n}\n/*Текст слева модального окна*/\n.uap-modal-left-text{\n    text-align: left;\n    font-size: 17px;\n    margin: 10px !important;\n    margin-top:20px;\n    margin-bottom: 20px;\n    font-family: 'Times New Roman', Times, serif\n}\n.uap-modal-left-text-margin {\n    margin: 24px;\n}\n\n.uap-modal-left-text-padding-bottom {\n    margin-bottom: 35px !important;\n}\n\nul.uap-modal-cookies-ul{\n    list-style-type: none;\n    padding: 0px;\n}\n\nul.uap-modal-cookies-ul > li.uap-modal-cookies-li:before{\n    content: \"- \";\n    text-indent: -5px;\n}\n\n.uap-modal-rule-left-text{\n    text-align: left;\n    font-family: \"Roboto\", sans-serif;\n    font-style: normal;\n    font-weight: normal;\n    font-size: 13px;\n    line-height: 20px;\n    color: #334059;\n    margin-top:20px !important;\n    margin-bottom: 20px !important;\n}\n\n.uap-modal-cookies-left-text{\n    text-align: left;\n    font-family: \"Roboto\", sans-serif;\n    font-style: normal;\n    font-weight: normal;\n    font-size: 13px;\n    line-height: 20px;\n    color: #334059;\n}\n/*Текст по центру тела окна*/\n.uap-modal-center-text{\n    text-align: center;\n    font-size: 17px;\n    margin: 10px !important;\n    margin-top:20px !important;\n    margin-bottom: 20px !important;\n    font-family: 'Times New Roman', Times, serif\n}\n\n/*Заголовок окна*/\n.uap-modal-left-title{\n    text-align: left;\n    margin: 15px !important;\n    font-weight: bold;\n    color: rgb(70, 69, 69);\n    font-family: sans-serif;\n    font-size: 18px;\n}\n\n.uap-modal-rule-left-title,\n.uap-modal-cookies-left-title{\n    text-align: left;\n    margin: 15px !important;\n    font-weight: bold;\n    font-family: \"Roboto\", sans-serif;\n    font-size: 17px;\n    color: #334059;\n}\n/*Заголовок окна по центру*/\n.uap-modal-center-title{\n    text-align: center;\n    margin: 15px !important;\n    font-weight: bold;\n    color: rgb(70, 69, 69);\n    font-family: sans-serif;\n    font-size: 18px;\n}\n/*Контейнер для кнопок*/\n.uap-modal-btn-container{\n    text-align: center;\n    margin: 10px;\n}\n\n.uap-modal-btn-container-large{\n    text-align: right;\n    margin: 10px;\n}\n\n.uap-modal-rule-btn-container,\n.uap-modal-cookies-btn-container{\n    position: relative;\n    margin: 10px;\n    height: 60px;\n}\n\n.uap-modal-graphical-shell-btn-container{\n    position: relative;\n    margin: 10px;\n    height: 40px;\n}\n\n/*Кнопка закрыть*/\nbutton.uap-modal-close{\n    background-color: #fefefe;\n    border: none;\n    font-size: 16px;\n    color: #0f9cd6;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    margin-right: 5px;\n    opacity: 0.9;\n    cursor: pointer;\n}\n\nbutton.uap-modal-rule-close,\nbutton.uap-modal-cookies-close{\n    background-color: #fefefe;\n    border: none;\n    font-weight: bold;\n    font-size: 12px;\n    color: #0068BD;;\n    font-family: \"Roboto\", sans-serif;\n    margin-right: 5px;\n    opacity: 0.9;\n    cursor: pointer;\n    top: 13px;\n    left: 16px;\n    position: absolute;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    line-height: 16px;\n}\n\nbutton.uap-modal-rule-close:hover,\nbutton.uap-modal-cookies-close:hover{\n    color: #4b7ba7;\n}\n\nbutton.uap-btn-margin{\n    margin-right: 50px;\n}\n/*Кнопка установить*/\nbutton.uap-modal-dark-blue{\n    background-color: #005cbf;\n    border: none;\n    color: #c5dbe4;\n    border-radius: 5px;\n    padding: 10px 20px;\n    margin-left: 5px;\n    margin-right: 5%;\n    font-size: 14px;\n    font-weight: bold;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    opacity: 0.9;\n    cursor: pointer;\n}\n\nbutton.uap-modal-install{\n    background-color: #0f9cd6;\n    border: none;\n    color: #c5dbe4;\n    border-radius: 5px;\n    padding: 10px 20px;\n    margin-left: 5px;\n    font-size: 16px;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    opacity: 0.9;\n    cursor: pointer;\n}\n\nbutton.uap-modal-install:hover{\n    opacity: 1;\n    color: white;\n}\n\nbutton.uap-modal-rule-install,\nbutton.uap-graphical-shell-install{\n    background-color: #0068BD;\n    border: none;\n    color: #ffffff;\n    border-radius: 4px;\n    padding: 0px 0px 0px 0px;\n    margin-left: 5px;\n    font-size: 12px;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    font-family: \"Roboto\", sans-serif;\n    opacity: 0.9;\n    cursor: pointer;\n    position: absolute;\n    right: 13px;\n    font-weight: bold;\n    width: 180px;\n    height: 40px;\n}\n\nbutton.uap-modal-rule-install:hover{\n    opacity: 1;\n    color: white;\n}\n\nbutton.uap-modal-yes {\n    background-color: #7a7d7e;\n    border: none;\n    color: #c5dbe4;\n    padding: 5px 40px;\n    margin-left: 10px;\n    margin-right: 10px;\n    font-size: 16px;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    opacity: 0.9;\n    text-align:center;\n    cursor: pointer;\n}\n\nbutton.uap-modal-no {\n    background-color: #0f9cd6;\n    border: none;\n    color: #c5dbe4;\n    padding: 5px 40px;\n    margin-left: 10px;\n    margin-right: 10px;\n    font-size: 16px;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    opacity: 0.9;\n    text-align:center;\n    cursor: pointer;\n}\n\n\nbutton.uap-modal-dark-blue:hover{\n    opacity: 1;\n    color: white;\n}\nbutton.uap-modal-close:hover{\n    color: #0b7aa7;\n}\n\nbutton.uap-modal-close-with-border{\n    background-color: #fefefe;\n    border: 1px solid #005cbf;\n    border-radius: 6px;\n    padding: 10px 20px;\n    color: #005cbf;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    margin-right: 3%;\n    opacity: 0.9;\n    font-size: 14px;\n    font-weight: bold;\n    cursor: pointer;\n}\n\nbutton.uap-modal-close-with-border:hover{\n    color: #fefefe;\n    background-color: #005cbf;\n}\n\n/* Стили для оверлея и текста на оверлее */\n.uap-overlay-content\n{\n    position: fixed;\n    z-index: 10002;\n    left: 0;\n    top: 0;\n    width: 100%;\n    height: 100%;\n    overflow: auto;\n    background-color: rgba(0, 0, 0, 0.7);\n\n}\n\n.uap-overlay-text{\n    font-size: 40px;\n    color: white;\n    text-align: center;\n    line-height: normal;\n}\n/* Стили для изображений дисплеев на оверлее */\nimg.uap-overlay-image {\n     border: 4px solid rgba(0, 255, 69, 0);\n     padding: 5px;\n     margin: 15px ;\n }\n\nimg.uap-overlay-image-selected {\n    border: 4px solid rgb(0, 216, 55);\n    padding: 5px;\n    margin: 15px ;\n}\n\nimg.uap-overlay-image:hover {\n    border: 4px solid #1089dd;\n}\n\n/* Контейнер для изображений */\ndiv.uap-image-container {\n   margin:auto;\n   max-width: max-content;\n   text-align:center;\n   align-content: center;\n}\n\n/* Кнопка \"Выбрать\" на оверлее */\nbutton#uap-overlay-choose{\n    display: block;\n    margin: auto;\n    background-color: #fffdf1;\n    border: none;\n    color: #0f9cd6;\n    font-weight: bold;\n    padding: 10px;\n    border-radius: 5px;\n    font-size: 16px;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    cursor: pointer;\n    display: block;\n}\n\nbutton#uap-overlay-choose:disabled:hover{\n    display: block;\n    margin: auto;\n    background-color: #fffdf1;\n    border: none;\n    color: #0f9cd6;\n    padding: 10px;\n    border-radius: 5px;\n    font-size: 16px;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    cursor: default;\n    display: block;\n}\n\nbutton#uap-overlay-choose:hover{\n    background-color: #0f9cd6;\n    color: #fffdf1;\n    border-radius: 5px;\n}\n\n\nbutton#uap-overlay-choose:active {\n    background-color: #007fd6;\n    color: #fffdf1;\n}\n\n\n/* Крестик справа в углу на оверлее для закрытия оверлея */\n.uap-overlay-close-cross {\n    position: absolute;\n    right: 32px;\n    top: 32px;\n    width: 32px;\n    height: 32px;\n    opacity: 0.3;\n    cursor:pointer;\n}\n\n.uap-overlay-close-cross:hover {\n    opacity: 1;\n}\n\n.uap-overlay-close-cross:active {\n    opacity: 0.6;\n}\n\n.uap-overlay-close-cross:before, .uap-overlay-close-cross:after {\n    position: absolute;\n    left: 15px;\n    content: ' ';\n    height: 33px;\n    width: 2px;\n    background-color: #ffffff;\n}\n\n.uap-overlay-close-cross:before {\n    transform: rotate(45deg);\n}\n\n.uap-overlay-close-cross:after {\n    transform: rotate(-45deg);\n}\n\n.uap-overlay-preloader {\n    position: fixed;\n  left: 0px;\n  top: 0px;\n  width: 100%;\n  height: 100%;\n  z-index: 9999;\n  background: url('data:image/gif;base64,') \n              50% 50% no-repeat rgb(0,0,0, 0.2);\n}\n.wrapper-uap-overlay-content{\n    left:calc(50% - 350px);\n    top:calc(50% - 175px);\n    width: 700px;\n    height:350px;\n    position: fixed;\n}</style>\n\n  \n    \n    \n      <link type=\"text/css\" rel=\"stylesheet\" media=\"all\" href=\"/epz/static/css/app.css\">\n      <link type=\"text/css\" rel=\"stylesheet\" href=\"/epz/static/css/jquery_msgbox.css\">\n    \n  \n\n  <script type=\"text/javascript\" src=\"/epz/static/js/jquery-3.3.1.min.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/jquery.cookie.min.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/js.cookie.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/jquery_msgBox.js\"></script>\n  <script type=\"text/javascript\">\n    \n    $(window).ready(function() {\n      $('body').animate({opacity:'1'},300);\n    });\n      function sessionTimeOutMsg(){\n          $.msgBox({\n              type:\"error\",\n              content:\"Время ожидания соединения истекло\",\n              title: \"Сообщение\",\n              afterClose: function(result) {\n                  document.location.href = \"\"\n              }\n          });\n      }\n\n      var isRegisteredUserObozApp = Boolean(\"\");\n      var sessionMaxInactiveInterval = \"600\";\n      $(document).ready(function(){\n          var notUsual = (($.cookie(\"usePoorVisionOption\") == 'true') && $(\".goodVisionLink\").length == 0);\n          var notPoorVision = (($.cookie(\"usePoorVisionOption\") != 'true') && $(\".poorVisionLink\").length == 0);\n          if (notUsual || notPoorVision){\n              location.reload();\n          }\n      });\n  </script>\n  <script>window.jQuery || document.write('<script src=\"/epz/static/js/jquery-3.3.1.min.js\"><\\/script>')</script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/ui_autocomplete.js\"></script>\n  \n  \n  <script type=\"text/javascript\" src=\"/epz/static/js/mustache.min.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/jquery.price_format.1.7.js\"></script>\n  \n  <script type=\"text/javascript\" src=\"/epz/static/js/moment.min.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/moment-timezone.min.js\"></script>\n\n  <script type=\"text/javascript\" src=\"/epz/static/js/action-switch.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/browser.js\"></script>\n  \n    \n    \n      <script type=\"text/javascript\" src=\"/epz/static/js/app.js\"></script>\n    \n  \n  <script type=\"text/javascript\" src=\"/epz/static/js/script.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/cards_keyboard_control_script.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/custom.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/URI.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/common/hints.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/common/config.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/common/analytics.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/cardBaseLayout.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/customScrollbar.js\"></script><script type=\"text/javascript\" src=\"/epz/static/js/jquery.mousewheel.min.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/common/ssl-checker.js\"></script>\n  \n      \n      \n          <script type=\"text/javascript\" src=\"/epz/static/js/keyboardNavigationRules.js\"></script>\n      \n  \n  <script type=\"text/javascript\" src=\"/epz/static/js/keyboardControl.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/jquery-migrate-3.0.1.min.js\"></script>\n  <script type=\"text/javascript\">\n      var contextPath = \"/epz/contract\";\n      var epzMainPublicUrl = \"/epz/main/public/\";\n  </script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/checkNotice.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/common/attachments-common-tab.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/generalPagination.js\"></script>\n  <script type=\"text/javascript\" src=\"/epz/static/js/generalChevron.js\"></script>\n\n  \n\n\n\n<script type=\"text/javascript\">\n    epzCommonConfig.initCommonConfig({\n        contextPath: '/epz/contract',\n        smartSearchEnable: true,\n\n        urls: {\n            epzMainPublicUrl: '/epz/main/public/',\n            epzNsiUrl: '/epz/nsi/',\n            epzOrderUrl: '/epz/order/',\n            epzOrderPlanUrl: '/epz/orderplan/',\n            epzOrderClauseUrl: '/epz/orderclause/',\n            epzContractUrl: '/epz/contract/',\n            epzContractFz223Url: '/epz/contractfz223/',\n            epzContractReportingUrl: '/epz/contractreporting/',\n            epzCustomerReportsUrl: '/epz/customerreports/',\n            epzOrganizationUrl: '/epz/organization/',\n            epzDishonestSupplierUrl: '/epz/dishonestsupplier/',\n            epzComplaintUrl: '/epz/complaint/',\n            epzBankGuaranteeUrl: '/epz/bankguarantee/',\n            epzInspectionPlanUrl: '/epz/inspectionplan/',\n            epzUnscheduledInspectionUrl: '/epz/unscheduledinspection/',\n            epzControlResultUrl: '/epz/controlresult/',\n            epzDizkUrl: '/epz/dizk/',\n            epzEsUrl: '/analytics/hit/',\n            epzFarmUrl: '/epz/farm/'\n        }\n    });\n</script>\n\n</head>\n<body class=\"cardLayout\" style=\"opacity: 1;\">\n\n<script type=\"text/javascript\">\n  if ($.cookie('usePoorVisionOption') === 'true') {\n    var body = $('body');\n    var style = '';\n    var cookie = $.cookie('colorSpectrumForPoorVision');\n    if (cookie) {\n      body.addClass(cookie + 'ColorSpectrum');\n      switch (cookie) {\n        case 'white':\n          style = '#ffffff';\n          break;\n        case 'black':\n          style = '#000000';\n          break;\n        case 'blue':\n          style = '#9DD1FF';\n          break;\n        case 'brown':\n          style = '#442713';\n          break;\n        case 'biege':\n          style = '#F7F3D6';\n          break;\n        default:\n          break;\n      }\n      body.css({backgroundColor: style});\n    }\n\n    var fontZize = $.cookie('fontSizeForPoorVision');\n    if (fontZize) {\n      body.addClass('fontSizeForPoorVision' + fontZize);\n    }\n  }\n</script>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n        \n        \n        \n        \n        \n        \n        \n        \n        \n    \n\n\n\n\n\n\n\n\n\n\n\n<style>\n    .header-logo {\n        top: -5px;\n        background: none;\n    }\n</style>\n\n<div id=\"critical_notice\"></div>\n\n    \n    \n        <header class=\"header header-top\">\n            <div class=\"container\">\n                <div class=\"row align-items-center\">\n                    <div class=\"col-5\" style=\"z-index: 1;\">\n                        <span class=\"logo text-base-micro\">Официальный сайт Единой информационной системы в сфере закупок</span>\n                    </div>\n                    <div class=\"col-1\"></div>\n                    <div class=\"col-3\">\n                        <a data-modalup=\"\" href=\"/epz/nsi/kladr/chooseRegion.html\">\n                            <div class=\"region d-flex align-items-center pr-0\" data-toggle=\"modal-region\" data-target=\".modal-region\">\n                      <span class=\"region-city w-space-nowrap\">\n                        <span class=\"region-city__icon\">\n                          <img src=\"/epz/static/img/icons/icon_region.svg\" title=\"Информация о местоположении пользователя используется в поисковых запросах для динамической детализации результатов поиска.\">\n                        </span>\n                        <span class=\"region-city__text region-city__text_base text-base-micro\">Мой регион: </span>\n                      </span>\n                                <span id=\"chooseRegion\">\n                                <span class=\"region-city pl-1\">\n                        <span class=\"region-city__text region-city__text_prime text-base-micro region_name\" id=\"popUpUserRegion\">Не выбран</span>\n                      </span>\n                                <span class=\"region-city__icon pl-1\">\n                            <img src=\"/epz/static/img/icons/icon_arrow_region.svg\" alt=\"\">\n                      </span>\n                                </span>\n                            </div>\n                        </a>\n                    </div>\n                    <div class=\"col-1\">\n                        <div class=\"header-links-group offset-block\">\n                            <a href=\"#\" class=\"header-link header-link_top\">\n                                <span class=\"header-link__icon poorVisionLink\">\n                                  <img class=\"glass-icon\" src=\"/epz/static/img/icons/icon_eye.svg\" alt=\"\">\n                                </span>\n                            </a>\n                        </div>\n                    </div>\n                    <div class=\"col-2\">\n                        <div class=\"account\">\n                            <div class=\"account-block\">\n                        <span class=\"icon\">\n                            <img src=\"/epz/static/img/icons/icon_user.svg\" alt=\"\">\n                        </span>\n                                <span class=\"text padLeft4\">Личный кабинет</span>\n                                <span class=\"button-open icon\">\n                            <img src=\"/epz/static/img/icons/icon_arrow_lk.svg\" alt=\"\">\n                        </span>\n                            </div>\n                            <ul class=\"account-vars\">\n                                <li class=\"account__var\" data-toggle=\"modal-account44\">\n                                    <a class=\"account__link\" data-modalup=\"\" href=\"/epz/main/public/chooseAuth44.html\" target=\"_blank\">\n                                <span class=\"icon\">\n                                  <img src=\"/epz/static/img/icons/arrow.svg\" alt=\"\">\n                                </span>\n                                        <span class=\"text text_bottom\">Личный кабинет</span>\n                                        <span class=\"subtext\">44-Ф3</span>\n              
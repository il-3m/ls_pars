100px */\r\n    background: #c7d1e0;\r\n}\r\n.uap-recordPanel__circle{\r\n    vertical-align: super;\r\n}\r\n\r\n.uap-buttonStop{\r\n    border: none;\r\n    width: 100%;\r\n    background-color: white;\r\n    background: url(data:image/png;base64,) no-repeat 10% 50%;\r\n    background-size: 35px;\r\n    height: 44px !important;\r\n    padding: 8px;\r\n}\r\n\r\n.uap-buttonStop:hover{\r\n    background: url(data:image/png;base64,) no-repeat 10% 50%;\r\n    background-size: 35px;\r\n    background-color: rgb(243, 243, 243);\r\n    padding:8px;\r\n    cursor: pointer;\r\n}\r\n\r\n.uap-recordPanel__btn{\r\n    cursor: pointer;\r\n}\r\n\r\n.uap-buttonStop p{\r\n    margin:0px;\r\n    margin-left: 50px !important;\r\n    user-select: none;\r\n}\r\n.uap-textRecord{\r\n    margin: 0px;\r\n    font-size: 22px;\r\n    cursor: default;\r\n}\r\n.uap-textRecord::selection{\r\n    background: transparent;\r\n}\r\n.uap-img_circle{\r\n    margin-top: 60%;\r\n    margin-bottom: 40%;\r\n    padding-left: 10px;\r\n}\r\n.uap-imgClose{\r\n    width: 20px;\r\n    margin: 8px 5px 5px;\r\n}"],["STYLE",{},".show-menu {\n    text-decoration: none;\n    width: 200px;\n    text-align: left;\n    height: 50px;\n}\n.menu__item{\n    border: 1px solid black;\n    width: 200px;\n    padding: 8px;\n    background: #F2F2F2;\n    cursor: pointer;\n    height: 30px;\n}\n\n.show-menu:hover {\n    cursor: pointer;\n    color: blue;\n}\n\n.menu {\n    margin: 0;\n    padding: 0;\n    list-style: none;\n}\n\n.menu--hide {\n    display: none;\n}\n\n.menu--show {\n    display: block;\n}\n"],["STYLE",{},"/*МО*/\n.uap-modal-update,\n.uap-modal-limit,\n.uap-modal-continue,\n.uap-modal-no-response,\n.uap-modal-no-support,\n.uap-modal-is-running,\n.uap-modal-success-update,\n.uap-modal-update-wait,\n.uap-modal-plugin-rule,\n.uap-modal-graphical-shell,\n.uap-modal-error-update {\n    position: fixed;\n    z-index: 10001;\n    align-items: center;\n    display: flex;\n    left: 0;\n    top: 0;\n    width: 100%;\n    height: 100%;\n    overflow: auto;\n    background-color: rgba(0,0,0,0.4);\n}\n\n/*МО фон*/\n.uap-modal-content {\n    background-color: #fefefe;\n    margin: auto;\n    border: 1px solid #888;\n    max-width: 430px;\n    font-family: serif;\n}\n\n.uap-modal-content-large{\n    background-color: #fefefe;\n    margin: auto;\n    border: 1px solid #888;\n    max-width: 590px;\n    font-family: serif;\n}\n\n.uap-modal-content-large-no-plugin{\n    background-color: #fefefe;\n    margin: auto;\n    border: 1px solid #888;\n    max-width: 630px;\n    font-family: serif;\n}\n\n.uap-modal-large {\n    max-width: 600px !important;\n    width: 528px;\n}\n.uap-rule-modal-title {\n    margin: 24px 24px 30px 24px !important;\n}\n\n/*Текст ошибки*/\n.uap-modal-text-error{\n    color: red;\n    font-weight: bold;\n    font-size: 15px;\n    text-align: left;\n    margin: 10px;\n}\n/*Контейнер содержимого МО*/\n.uap-modal-container-content{\n     border-top: 1px #dbdfec solid;\n     border-bottom: 1px #dbdfec solid;\n     width: 100%;\n }\n\n.uap-modal-container-content-no-top-border{\n    border-bottom: 1px #dbdfec solid;\n    width: 100%;\n}\n/*Текст слева модального окна*/\n.uap-modal-left-text{\n    text-align: left;\n    font-size: 17px;\n    margin: 10px !important;\n    margin-top:20px;\n    margin-bottom: 20px;\n    font-family: 'Times New Roman', Times, serif\n}\n.uap-modal-left-text-margin {\n    margin: 24px;\n}\n\n.uap-modal-left-text-padding-bottom {\n    margin-bottom: 35px !important;\n}\n\nul.uap-modal-cookies-ul{\n    list-style-type: none;\n    padding: 0px;\n}\n\nul.uap-modal-cookies-ul > li.uap-modal-cookies-li:before{\n    content: \"- \";\n    text-indent: -5px;\n}\n\n.uap-modal-rule-left-text{\n    text-align: left;\n    font-family: \"Roboto\", sans-serif;\n    font-style: normal;\n    font-weight: normal;\n    font-size: 13px;\n    line-height: 20px;\n    color: #334059;\n    margin-top:20px !important;\n    margin-bottom: 20px !important;\n}\n\n.uap-modal-cookies-left-text{\n    text-align: left;\n    font-family: \"Roboto\", sans-serif;\n    font-style: normal;\n    font-weight: normal;\n    font-size: 13px;\n    line-height: 20px;\n    color: #334059;\n}\n/*Текст по центру тела окна*/\n.uap-modal-center-text{\n    text-align: center;\n    font-size: 17px;\n    margin: 10px !important;\n    margin-top:20px !important;\n    margin-bottom: 20px !important;\n    font-family: 'Times New Roman', Times, serif\n}\n\n/*Заголовок окна*/\n.uap-modal-left-title{\n    text-align: left;\n    margin: 15px !important;\n    font-weight: bold;\n    color: rgb(70, 69, 69);\n    font-family: sans-serif;\n    font-size: 18px;\n}\n\n.uap-modal-rule-left-title,\n.uap-modal-cookies-left-title{\n    text-align: left;\n    margin: 15px !important;\n    font-weight: bold;\n    font-family: \"Roboto\", sans-serif;\n    font-size: 17px;\n    color: #334059;\n}\n/*Заголовок окна по центру*/\n.uap-modal-center-title{\n    text-align: center;\n    margin: 15px !important;\n    font-weight: bold;\n    color: rgb(70, 69, 69);\n    font-family: sans-serif;\n    font-size: 18px;\n}\n/*Контейнер для кнопок*/\n.uap-modal-btn-container{\n    text-align: center;\n    margin: 10px;\n}\n\n.uap-modal-btn-container-large{\n    text-align: right;\n    margin: 10px;\n}\n\n.uap-modal-rule-btn-container,\n.uap-modal-cookies-btn-container{\n    position: relative;\n    margin: 10px;\n    height: 60px;\n}\n\n.uap-modal-graphical-shell-btn-container{\n    position: relative;\n    margin: 10px;\n    height: 40px;\n}\n\n/*Кнопка закрыть*/\nbutton.uap-modal-close{\n    background-color: #fefefe;\n    border: none;\n    font-size: 16px;\n    color: #0f9cd6;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    margin-right: 5px;\n    opacity: 0.9;\n    cursor: pointer;\n}\n\nbutton.uap-modal-rule-close,\nbutton.uap-modal-cookies-close{\n    background-color: #fefefe;\n    border: none;\n    font-weight: bold;\n    font-size: 12px;\n    color: #0068BD;;\n    font-family: \"Roboto\", sans-serif;\n    margin-right: 5px;\n    opacity: 0.9;\n    cursor: pointer;\n    top: 13px;\n    left: 16px;\n    position: absolute;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    line-height: 16px;\n}\n\nbutton.uap-modal-rule-close:hover,\nbutton.uap-modal-cookies-close:hover{\n    color: #4b7ba7;\n}\n\nbutton.uap-btn-margin{\n    margin-right: 50px;\n}\n/*Кнопка установить*/\nbutton.uap-modal-dark-blue{\n    background-color: #005cbf;\n    border: none;\n    color: #c5dbe4;\n    border-radius: 5px;\n    padding: 10px 20px;\n    margin-left: 5px;\n    margin-right: 5%;\n    font-size: 14px;\n    font-weight: bold;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    opacity: 0.9;\n    cursor: pointer;\n}\n\nbutton.uap-modal-install{\n    background-color: #0f9cd6;\n    border: none;\n    color: #c5dbe4;\n    border-radius: 5px;\n    padding: 10px 20px;\n    margin-left: 5px;\n    font-size: 16px;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    opacity: 0.9;\n    cursor: pointer;\n}\n\nbutton.uap-modal-install:hover{\n    opacity: 1;\n    color: white;\n}\n\nbutton.uap-modal-rule-install,\nbutton.uap-graphical-shell-install{\n    background-color: #0068BD;\n    border: none;\n    color: #ffffff;\n    border-radius: 4px;\n    padding: 0px 0px 0px 0px;\n    margin-left: 5px;\n    font-size: 12px;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    font-family: \"Roboto\", sans-serif;\n    opacity: 0.9;\n    cursor: pointer;\n    position: absolute;\n    right: 13px;\n    font-weight: bold;\n    width: 180px;\n    height: 40px;\n}\n\nbutton.uap-modal-rule-install:hover{\n    opacity: 1;\n    color: white;\n}\n\nbutton.uap-modal-yes {\n    background-color: #7a7d7e;\n    border: none;\n    color: #c5dbe4;\n    padding: 5px 40px;\n    margin-left: 10px;\n    margin-right: 10px;\n    font-size: 16px;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    opacity: 0.9;\n    text-align:center;\n    cursor: pointer;\n}\n\nbutton.uap-modal-no {\n    background-color: #0f9cd6;\n    border: none;\n    color: #c5dbe4;\n    padding: 5px 40px;\n    margin-left: 10px;\n    margin-right: 10px;\n    font-size: 16px;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    opacity: 0.9;\n    text-align:center;\n    cursor: pointer;\n}\n\n\nbutton.uap-modal-dark-blue:hover{\n    opacity: 1;\n    color: white;\n}\nbutton.uap-modal-close:hover{\n    color: #0b7aa7;\n}\n\nbutton.uap-modal-close-with-border{\n    background-color: #fefefe;\n    border: 1px solid #005cbf;\n    border-radius: 6px;\n    padding: 10px 20px;\n    color: #005cbf;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    margin-right: 3%;\n    opacity: 0.9;\n    font-size: 14px;\n    font-weight: bold;\n    cursor: pointer;\n}\n\nbutton.uap-modal-close-with-border:hover{\n    color: #fefefe;\n    background-color: #005cbf;\n}\n\n/* Стили для оверлея и текста на оверлее */\n.uap-overlay-content\n{\n    position: fixed;\n    z-index: 10002;\n    left: 0;\n    top: 0;\n    width: 100%;\n    height: 100%;\n    overflow: auto;\n    background-color: rgba(0, 0, 0, 0.7);\n\n}\n\n.uap-overlay-text{\n    font-size: 40px;\n    color: white;\n    text-align: center;\n    line-height: normal;\n}\n/* Стили для изображений дисплеев на оверлее */\nimg.uap-overlay-image {\n     border: 4px solid rgba(0, 255, 69, 0);\n     padding: 5px;\n     margin: 15px ;\n }\n\nimg.uap-overlay-image-selected {\n    border: 4px solid rgb(0, 216, 55);\n    padding: 5px;\n    margin: 15px ;\n}\n\nimg.uap-overlay-image:hover {\n    border: 4px solid #1089dd;\n}\n\n/* Контейнер для изображений */\ndiv.uap-image-container {\n   margin:auto;\n   max-width: max-content;\n   text-align:center;\n   align-content: center;\n}\n\n/* Кнопка \"Выбрать\" на оверлее */\nbutton#uap-overlay-choose{\n    display: block;\n    margin: auto;\n    background-color: #fffdf1;\n    border: none;\n    color: #0f9cd6;\n    font-weight: bold;\n    padding: 10px;\n    border-radius: 5px;\n    font-size: 16px;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    cursor: pointer;\n    display: block;\n}\n\nbutton#uap-overlay-choose:disabled:hover{\n    display: block;\n    margin: auto;\n    background-color: #fffdf1;\n    border: none;\n    color: #0f9cd6;\n    padding: 10px;\n    border-radius: 5px;\n    font-size: 16px;\n    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial;\n    cursor: default;\n    display: block;\n}\n\nbutton#uap-overlay-choose:hover{\n    background-color: #0f9cd6;\n    color: #fffdf1;\n    border-radius: 5px;\n}\n\n\nbutton#uap-overlay-choose:active {\n    background-color: #007fd6;\n    color: #fffdf1;\n}\n\n\n/* Крестик справа в углу на оверлее для закрытия оверлея */\n.uap-overlay-close-cross {\n    position: absolute;\n    right: 32px;\n    top: 32px;\n    width: 32px;\n    height: 32px;\n    opacity: 0.3;\n    cursor:pointer;\n}\n\n.uap-overlay-close-cross:hover {\n    opacity: 1;\n}\n\n.uap-overlay-close-cross:active {\n    opacity: 0.6;\n}\n\n.uap-overlay-close-cross:before, .uap-overlay-close-cross:after {\n    position: absolute;\n    left: 15px;\n    content: ' ';\n    height: 33px;\n    width: 2px;\n    background-color: #ffffff;\n}\n\n.uap-overlay-close-cross:before {\n    transform: rotate(45deg);\n}\n\n.uap-overlay-close-cross:after {\n    transform: rotate(-45deg);\n}\n\n.uap-overlay-preloader {\n    position: fixed;\n  left: 0px;\n  top: 0px;\n  width: 100%;\n  height: 100%;\n  z-index: 9999;\n  background: url('data:image/gif;base64,') \n              50% 50% no-repeat rgb(0,0,0, 0.2);\n}\n.wrapper-uap-overlay-content{\n    left:calc(50% - 350px);\n    top:calc(50% - 175px);\n    width: 700px;\n    height:350px;\n    position: fixed;\n}"],"\n\n  \n    \n    \n      ",["LINK",{"type":"text/css","rel":"stylesheet","media":"all","href":"/epz/static/css/app.css"}],"\n      
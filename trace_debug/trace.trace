                                          <span class=\"section__title\">Вид первичной упаковки</span>\n                                                <span class=\"section__info\">БУТЫЛЬ</span>\n                                            </section>\n                                            <section class=\"blockInfo__section section\">\n                                                <span class=\"section__title\">Количество лекарственных форм в первичной упаковке</span>\n                                                <span class=\"section__info\">200</span>\n                                            </section>\n                                            <section class=\"blockInfo__section section\">\n                                                <span class=\"section__title\">Количество первичных упаковок в потребительской упаковке</span>\n                                                <span class=\"section__info\">35</span>\n                                            </section>\n                                            <section class=\"blockInfo__section section\">\n                                                <span class=\"section__title\">Количество потребительских единиц в потребительской упаковке</span>\n                                                <span class=\"section__info\">7000</span>\n                                            </section>\n                                            \n                                                <section class=\"blockInfo__section section\">\n                                                    <span class=\"section__title\">Комплектность потребительской упаковки</span>\n                                                    <span class=\"section__info\">~</span>\n                                                </section>\n                                            \n                                        </div>\n                                    </td>\n                                </tr>\n   
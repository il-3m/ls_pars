\n    \n\n\n\n    \n\n\n\n    \n\n\n\n    \n\n\n<div class=\"d-flex justify-content-between align-items-baseline\">\n    \n\n\n\n\n\n\n\n\n\n\n\n    \n\n<script type=\"text/javascript\" src=\"/epz/static/js/pagination/jquery.simplePagination.js\"></script>\n<script type=\"text/javascript\" src=\"/epz/static/js/pagination/script.js\"></script>\n\n<div id=\"contractSubjectSearchPosition\">\n\n    <div id=\"contractSubjectSearchPositionNavigation\" class=\"paginator\"><ul class=\"pages\"><li class=\"page disabled\"><a class=\"page__link page__link_active prev\"><span><img src=\"/epz/static/img/icons/arrow-prime.svg\" style=\"transform: rotate(180deg)\"></span></a></li><li class=\"page active\"><a class=\"page__link page__link_active\"><span>1</span></a></li><li class=\"page\"><a href=\"#page-2\" class=\"page__link\">2</a></li><li class=\"page\"><a href=\"#page-2\" class=\"page__link next\"><img src=\"/epz/static/img/icons/arrow-prime.svg\"></a></li></ul></div>\n</div>\n<script type=\"text/javascript\">\n\n    function hidePaginationContainer(total, id, selector) {\n        if (total <= 10) {\n            $(\"#\"+id).closest(selector).hide();\n        } else {\n            $(\"#\"+id).closest(selector).show();\n        }\n    }\n\n    function contractSubjectSearchPositionPaginationContainerRenderPagination(size, id) {\n        $(\"#\"+id+\"Navigation\").pagination({\n            items: 15,\n            ellipsePageSet: false,\n            cssStyle: 'paginator',\n            listStyle: 'pages',\n            liStyleClass: 'page',\n            aStyleClass: 'page__link',\n            aCurrentStyleClass: 'page__link page__link_active',\n            prevText: '<img src=\"/epz/static/img/icons/arrow-prime.svg\" style=\"transform: rotate(180deg)\">',\n            nextText: '<img src=\"/epz/static/img/icons/arrow-prime.svg\">',\n            onPageClick: function(pageNumber, event) {\n                // Callback triggered when a page is clicked\n                // Page number is given as an optional parameter\n                contractSubjectAjaxSubmitForm(pageNumber, event);\n            },\n            itemsOnPage: size\n        });\n    }\n\n    contractSubjectSearchPositionPaginationContainerRenderPagination(10,'contractSubjectSearchPosition');\n</script>\n    \n        \n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n<div>\n    <div class=\"show-by align-self-center d-flex\">\n        <div class=\"align-self-center show-by__title\">Показать&nbsp;по&nbsp;:</div>\n        <div id=\"resultsPerPageSelector\" class=\"select-wrap align-self-center show-by__select\">\n            <div class=\"select-group\">\n                <div class=\"select select-text select-record-per-page--number\" data-selected-value=\"10\" data-select-then-eval-function=\"changePageSizeContractSubjectAjaxSubmitForm\">10</div>\n                <span class=\"select-icon\"></span>\n            </div>\n            <div class=\"select-group\">\n                <ul class=\"select-vars\">\n                    \n                        \n                            \n                                <li id=\"_10\" class=\"select-vars__item select-text select-vars__item--selected\">10</li>\n                            \n                                <li id=\"_20\" class=\"select-vars__item select-text\">20</li>\n                            \n                                <li id=\"_50\" class=\"select-vars__item select-text\">50</li>\n                            \n                        \n                        \n                    \n                </ul>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n    \n\n        <script type=\"text/javascript\">\n\n            $(document).ready(function () {\n\n                let resultsPerPageSelector = $(\"#resultsPerPageSelector\");\n\n                // Функция для получения уникального ключа на основе текущего контекста\n                function getContextKey(key) {\n                    const url = window.location.pathname; // Получаем путь текущей страницы\n                    const context = url.split('/').slice(0, 4).join('/'); // Используем первые части пути как контекст\n                    return `-`; // Создаем уникальный ключ для данного контекста\n                }\n\n                // Функция для сохранения номера последней реестровой записи в localStorage\n                function saveLastRecordNumber() {\n                    let lastRecord = Array.from(document.querySelectorAll('.registry-entry__header-mid__number'))\n                        .reverse()\n                        .find(el => {\n                            const link = el.querySelector('a');\n                            return link && link.textContent.trim().length > 0; // Проверяем, что текст не пустой\n                        });\n\n                    if (lastRecord) {\n                        const recordNumber = lastRecord.querySelector('a').textContent.trim()\n                        const key = getContextKey('lastRecordNumber'); // Генерируем уникальный ключ для данного контекста\n                        localStorage.setItem(key, recordNumber); // Сохраняем номер в localStorage\n                    }\n                }\n\n                // Функция для прокрутки к записи по её номеру\n                function scrollToRecordByNumber(recordNumber, key) {\n\n                    if (recordNumber) {\n\n                        let targetRecord = $('.registry-entry__header-mid__number')\n                            .filter((_, el) => $(el).find('a').text().trim() === recordNumber);\n\n                        $('html, body').animate({scrollTop: targetRecord.offset().top}, 500);\n\n                    }\n\n                    localStorage.removeItem(key);\n                }\n\n\n                // Обработчик события изменения количества результатов на странице\n                resultsPerPageSelector.find(\".select-vars__item.select-text\").on('click', saveLastRecordNumber);\n\n                // При загрузке страницы проверяем, есть ли сохранённый номер, и выполняем прокрутку\n                $(window).on('load', function () {\n                    const key = getContextKey('lastRecordNumber'); // Генерируем уникальный ключ для данного контекста\n                    const savedNumber = localStorage.getItem(key);\n\n                    scrollToRecordByNumber(savedNumber, key);\n                });\n            });\n        </script>\n    \n    \n\n    \n</div>\n                \n                <input type=\"hidden\" id=\"ulrRefresh\" value=\"/epz/contract/contractCard/payment-info-and-target-of-order-list.html?reestrNumber=2634000076026000017&amp;contractInfoId=108457024\">\n            </div>\n        </div>\n    </div>\n</div>\n<hr class=\"graySeparator\">\n\n\n\n    <div class=\"container\">\n        <div class=\"row blockInfo\">\n            <div class=\"col\">\n                <h2 class=\"blockInfo__title\">Платежные реквизиты</h2>\n                <div class=\"blockInfo__section\">\n                    <div class=\"paymentTable\">\n                        \n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n        \n        \n        \n        \n        \n        \n        \n        \n        \n    \n\n\n\n\n\n\n\n\n\n\n\n    \n\n    <div id=\"chevron_customer\" class=\"padTop20 padBottom20 font-weight-bold border-bottom border-top\">\n        <div class=\"row pl-1\">\n            <div class=\"col-12\">\n                <img src=\"/epz/static/img/icons/icon_expander_uncover.svg\" alt=\"Раскрыть\" class=\"draftArrow cursorPointer align-content-center pb-1 pl-0\" data-id=\"paymentDetailsChevron\" id=\"arr_customer\">\n                <span class=\"cost pl-2\">Реквизиты счёта заказчика</span>\n            </div>\n        </div>\n    </div>\n\n    \n\n    <table class=\"tableBlock grayBorderBottom d-none\" id=\"_customer\">\n        <thead>\n        \n        <tr class=\"tableBlock__row\">\n            <th class=\"tableBlock__col tableB
" +\n                \"&pageNumber=\" + pageNum +\n                \"&recordsPerPage=\" + pageSize +\n                \"&reestrNumber=\" + 2634000076026000017 +\n                    \"&budgetType=B\" +\n                \"&dataModelId=\" + dataModelId +\n                \"&tableId=\" + tableId,\n            success: function (html) {\n                $(\".innerHtml\").html(html);\n                let rise = new CustomEvent(\"reinitializeSelectEvent\", {\n                    detail: {\n                        selectorDom: tableId + ' .select-wrap'\n                    }\n                });\n                document.dispatchEvent(rise);\n            }\n        });\n    }\n\n    function goToPageFundsModel(pagNum,pageSize) {\n        let tableId = $(this).parent().find('table').attr('id');\n        searchFundsModel(pagNum, pageSize, tableId);\n    }\n</script>\n\n  </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n        \n        \n        \n        \n        \n        \n        \n        \n        \n    \n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<footer class=\"footer\">\n    <div class=\"wrapperFooter\">\n        \n            \n            \n                \n                    <div class=\"container\">\n                        <div class=\"poll-banner\">\n                            <div class=\"row align-items-center\">\n                                <div class=\"col-9\">\n                                    <div class=\"figure-footer d-flex align-items-center noselect\">\n                                        <div class=\"figure-footer__icon\">\n                                            <img src=\"/epz/static/img/icons/ico_sub.svg\" alt=\"\" class=\"icon\">\n                                        </div>\n                                        <div class=\"figure-footer__text\">\n                                            <h4 class=\"heading-h4 poll-title\">Поделитесь мнением о качестве работы единой\n                        